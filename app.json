{
  "expo": {
    "name": "SignBridge",
    "slug": "SignBridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "signbridge",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e27"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SignBridge needs camera access to detect sign language gestures."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a0e27"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.SignBridge",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-fast-tflite",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "SignBridge needs camera access to detect sign language gestures.",
          "enableFrameProcessors": true
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2b3f2f6-0948-4215-bd46-146b4d214b77"
      }
    },
    "owner": "gemver"
  }
}
